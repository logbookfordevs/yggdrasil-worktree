{
  "name": "yggtree",
  "version": "1.4.2",
  "packageManager": "pnpm@11.0.9",
  "description": "Interactive CLI for managing git worktrees and configs",
  "main": "dist/index.js",
  "type": "module",
  "repository": {
    "url": "git+https://github.com/logbookfordevs/yggdrasil-worktree.git",
    "type": "git"
  },
  "homepage": "yggtree.logbookfordevs.com",
  "bin": {
    "yggtree": "./bin/yggtree"
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "release:artifact": "scripts/build-release-artifact.sh",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "pnpm build && node scripts/test-env-files.mjs && node scripts/test-worktree-checkout-branches.mjs"
  },
  "keywords": [
    "cli",
    "git",
    "worktree",
    "productivity"
  ],
  "author": "Leonardo Dias",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "execa": "^8.0.1",
    "figlet": "^1.7.0",
    "fs-extra": "^11.2.0",
    "gradient-string": "^2.0.2",
    "inquirer": "^9.2.14",
    "inquirer-autocomplete-prompt": "^3.0.1",
    "ora": "^8.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/figlet": "^1.5.8",
    "@types/fs-extra": "^11.0.4",
    "@types/gradient-string": "^1.1.6",
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.11.19",
    "typescript": "^5.3.3"
  }
}
